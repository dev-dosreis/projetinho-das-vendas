# Supabase
# Encontre o Project URL em: Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave publishable/anon usada somente no servidor para leitura
SUPABASE_PUBLISHABLE_KEY=replace_me

# Chave secreta service role usada somente no servidor para aprovar/rejeitar/adiar
SUPABASE_SERVICE_ROLE_KEY=replace_me_server_only

# Compatibilidade Vercel, caso prefira configurar com nomes publicos.
# O app le essas variaveis apenas no servidor porque lib/supabase.ts usa server-only.
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_me

# LLM unica da V0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_KEY=

# Fallbacks de contato
APOLLO_API_KEY=
APOLLO_COMPANY_SEARCH_API_KEY=
APOLLO_ORGANIZATION_ENRICH_API_KEY=
HUNTER_API_KEY=

# Alertas server-side de falha do pipeline
ALERT_WEBHOOK_URL=

# Metricas
MONTHLY_STACK_COST_USD=0

# APIs de coleta para scripts/collect.mjs
FIRECRAWL_API_KEY=
FIRECRAWL_KEY=
PAGESPEED_API_KEY=
PSI_KEY=
BUILTWITH_API_KEY=
BUILTWITH_KEY=
HUNTER_KEY=
DNS_LOOKUP_API_KEY=
RDAP_BASE_URL=https://rdap.registro.br
