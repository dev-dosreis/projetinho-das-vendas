# Supabase
# Encontre o Project URL em: Supabase Dashboard -> Settings -> API -> Project URL
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave publishable/anon usada somente no servidor para leitura
SUPABASE_PUBLISHABLE_KEY=replace_me

# Chave secreta service role usada somente no servidor para aprovar/rejeitar/adiar
SUPABASE_SERVICE_ROLE_KEY=replace_me_server_only

# APIs de coleta para scripts/collect.mjs
FIRECRAWL_KEY=
PSI_KEY=
BUILTWITH_KEY=
HUNTER_KEY=
GEMINI_KEY=
